@model List<FileShare>

<html lang="en">
<head>
    <title>All Files - SecureFileShare</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>
    <div id="allFiles">
        <h1>Files Shared</h1>
        <p style="color:antiquewhite">Files shared with you or from you</p>

        <table class="table-dark table-bordered" id="fileTable">
            <thead>
                <tr>
                    <th>File Name</th>
                    <th>Size</th>
                    <th>Shared From</th>
                    <th>Shared To</th>
                    <th>Share Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var share in Model)
                {
                    <tr>
                        <td>@share.SharedFile.FileName</td>
                        <td>@(share.SharedFile.Size / 1024) KB</td>
                        <td>@share.SharedFrom.FirstName @share.SharedFrom.LastName</td>
                        <td>@share.SharedWith.FirstName @share.SharedWith.LastName</td>
                        <td>@share.ShareDate.ToString("dd-MM-yyyy HH:mm")</td>
                        <td>
                            <a asp-action="Download" asp-route-id="@share.SharedFile.FileId" class="btn btn-sm btn-success">Download</a>
                            @* <a asp-action="Delete" asp-route-id="@file.FileId" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this file?');">Delete</a> *@
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</body>
</html>
