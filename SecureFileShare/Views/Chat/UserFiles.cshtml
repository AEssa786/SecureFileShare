@model List<File>

<html lang="en">
<head>
    <title>All Files - SecureFileShare</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>
    <div id="allFiles">
        <h1>All Files</h1>

        <table class="table-dark table-bordered" id="fileTable">
            <thead>
                <tr>
                    <th>File Name</th>
                    <th>Size</th>
                    <th>Upload Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var file in Model)
                {
                    <tr>
                        <td>@file.FileName</td>
                        <td>@(file.Size / 1024) KB</td>
                        <td>@file.UploadDate.ToString("dd-MM-yyyy HH:mm")</td>
                        <td>
                            <a asp-action="SelectFile" asp-route-id="@file.FileId" class="btn btn-sm btn-primary">Select</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <a asp-action="Upload" id="uploadButton">Upload Files</a>
    </div>

</body>
</html>

