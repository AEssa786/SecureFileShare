@model List<File>

<h1>All Files</h1>

<a asp-action="Upload">Upload Files</a>
<table class="table">
    <thead>
        <tr>
            <th>File Name</th>
            <th>Size (KB)</th>
            <th>Upload Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var file in Model)
        {
            <tr>
                <td>@file.FileName</td>
                <td>@(file.Size/1024)</td>
                <td>@file.UploadDate.ToString("HH:mm dd-MM-yyyy")</td>
                <td>
                    <a asp-action="Download" asp-route-id="@file.FileId" class="btn btn-sm btn-success">Download</a>
                    <a asp-action="Delete" asp-route-id="@file.FileId" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this file?');">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

